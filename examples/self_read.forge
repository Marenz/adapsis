// A Forge program that reads its own source code and counts its lines

+fn count_lines (text:String)->Int
  +let lines:List<String> = split(text, "\n")
  +return lines.len
+end

+fn main ()->Int [io,async]
  +await source:String = file_read("examples/self_read.forge")
  +let line_count:Int = count_lines(source)
  +await ok:Int = file_write("/tmp/forge-self-read-result.txt", concat("This program has ", concat(to_string(line_count), " lines")))
  +return line_count
+end
