+fn test_json_array_len(json:String) -> Int
  +call n:Int = json_array_len(json)
  +return n
+end

+fn test_json_get_from_array(json:String) -> Int
  +call result:Int = json_get(json, "0")
  +return result
+end

+fn build_and_parse(dummy:Int) -> String
  +call json:String = concat("{", concat("\"name\":", concat("\"alice\"", "}")))
  +call result:String = json_get(json, "name")
  +return result
+end

+fn nested_array_access(dummy:Int) -> Int
  +call arr:String = concat("[", concat("10,20,30", "]"))
  +call val:Int = json_get(arr, "1")
  +return val
+end

!test test_json_array_len
  +with json="[1,2,3]" -> expect 3
  +with json="[]" -> expect 0

!test test_json_get_from_array
  +with json="[42,99]" -> expect 42

!test build_and_parse
  +with 0 -> expect "alice"

!test nested_array_access
  +with 0 -> expect 20
