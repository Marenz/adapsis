+type CreateRequest = {name:String, email:String}
+type User = {id:Int, name:String, email:String}

+fn create_user (req:CreateRequest, id:Int)->User
  +return {id: id, name: req.name, email: req.email}
+end

+test create_user
  +with name="alice" email="a@b.com" id=1 -> expect {id: 1, name: "alice", email: "a@b.com"}
  +with name="bob" email="b@c.com" id=42 -> expect {id: 42, name: "bob", email: "b@c.com"}
